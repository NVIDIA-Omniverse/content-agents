#usda 1.0
(
    defaultPrim = "World"
    metersPerUnit = 0.01
    upAxis = "Y"
    doc = """Test scene for Scene Optimizer operations.

    This scene contains geometry to test ALL operation combinations:

    Single operations:
    1. Deinstancing only (CUBES - 8 verts, 6 quad faces)
    2. Split GeomSubsets only (TRIANGULAR PRISMS - 12 verts, 10 faces)
    3. Deduplication only (SQUARE PYRAMIDS - 5 verts, 5 faces)

    Two-operation combinations:
    6. Deinstance + Split (HEXAGONAL DISCS - 7 verts, 6 tri faces)
    7. Deinstance + Dedup (FLAT DIAMONDS - 4 verts, 2 tri faces)
    8. Split + Dedup (ARROWS - 5 verts, 3 tri faces)

    All operations:
    4. Deinstance + Split + Dedup (DOUBLE TETRAHEDRONS - 8 verts, 8 tri faces)

    Control:
    5. No-op / Control group (OCTAHEDRON - 6 verts, 8 tri faces)

    NOTE: Each section uses DIFFERENT SHAPES with different vertex counts
    and face topologies. These cannot be matched by any transform.
    """
)

def Xform "World"
{
    # =========================================================================
    # SECTION 1: Deinstancing Test
    # Uses CUBES - 8 vertices, 6 quad faces
    # =========================================================================

    def Xform "DeinstancingTest"
    {
        def Mesh "PrototypeCube" (
            instanceable = true
        )
        {
            float3[] extent = [(-0.5, -0.5, -0.5), (0.5, 0.5, 0.5)]
            int[] faceVertexCounts = [4, 4, 4, 4, 4, 4]
            int[] faceVertexIndices = [0, 1, 2, 3, 4, 5, 6, 7, 0, 4, 7, 3, 1, 5, 6, 2, 0, 1, 5, 4, 3, 2, 6, 7]
            point3f[] points = [
                (-0.5, -0.5, -0.5), (0.5, -0.5, -0.5), (0.5, 0.5, -0.5), (-0.5, 0.5, -0.5),
                (-0.5, -0.5, 0.5), (0.5, -0.5, 0.5), (0.5, 0.5, 0.5), (-0.5, 0.5, 0.5)
            ]
            uniform token subdivisionScheme = "none"
        }

        def Xform "Instance1" (
            references = </World/DeinstancingTest/PrototypeCube>
            instanceable = true
        )
        {
            double3 xformOp:translate = (0, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }

        def Xform "Instance2" (
            references = </World/DeinstancingTest/PrototypeCube>
            instanceable = true
        )
        {
            double3 xformOp:translate = (2, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }

        def Xform "Instance3" (
            references = </World/DeinstancingTest/PrototypeCube>
            instanceable = true
        )
        {
            double3 xformOp:translate = (4, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }
    }

    # =========================================================================
    # SECTION 2: Split GeomSubsets Test
    # Uses TRIANGULAR PRISMS - 6 vertices, 2 triangle + 3 quad faces
    # =========================================================================

    def Xform "SplitGeomSubsetsTest"
    {
        double3 xformOp:translate = (0, 0, 5)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        # Two triangular prisms combined with GeomSubsets
        def Mesh "TwoPrismsMesh"
        {
            float3[] extent = [(-3, -0.5, -0.5), (3, 0.5, 0.5)]
            int[] faceVertexCounts = [3, 3, 4, 4, 4, 3, 3, 4, 4, 4]
            int[] faceVertexIndices = [
                # Prism 1 (left)
                0, 1, 2, 3, 4, 5, 0, 3, 5, 2, 0, 1, 4, 3, 1, 2, 5, 4,
                # Prism 2 (right)
                6, 7, 8, 9, 10, 11, 6, 9, 11, 8, 6, 7, 10, 9, 7, 8, 11, 10
            ]
            point3f[] points = [
                # Prism 1 (left)
                (-3, -0.5, -0.5), (-2, -0.5, -0.5), (-2.5, 0.5, -0.5),
                (-3, -0.5, 0.5), (-2, -0.5, 0.5), (-2.5, 0.5, 0.5),
                # Prism 2 (right)
                (2, -0.5, -0.5), (3, -0.5, -0.5), (2.5, 0.5, -0.5),
                (2, -0.5, 0.5), (3, -0.5, 0.5), (2.5, 0.5, 0.5)
            ]
            uniform token subdivisionScheme = "none"

            def GeomSubset "Prism_Left" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                uniform token elementType = "face"
                uniform token familyName = "materialBind"
                int[] indices = [0, 1, 2, 3, 4]
            }

            def GeomSubset "Prism_Right" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                uniform token elementType = "face"
                uniform token familyName = "materialBind"
                int[] indices = [5, 6, 7, 8, 9]
            }
        }
    }

    # =========================================================================
    # SECTION 3: Deduplication Test
    # Uses SQUARE PYRAMIDS - 5 vertices, 1 quad base + 4 triangle faces
    # =========================================================================

    def Xform "DeduplicationTest"
    {
        double3 xformOp:translate = (0, 0, 10)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        # 4 identical pyramids at different positions
        def Mesh "DuplicatePyramid1"
        {
            float3[] extent = [(-0.5, -0.5, -0.5), (0.5, 0.5, 0.5)]
            int[] faceVertexCounts = [4, 3, 3, 3, 3]
            int[] faceVertexIndices = [0, 1, 2, 3, 0, 1, 4, 1, 2, 4, 2, 3, 4, 3, 0, 4]
            point3f[] points = [
                (-0.5, -0.5, -0.5), (0.5, -0.5, -0.5), (0.5, -0.5, 0.5), (-0.5, -0.5, 0.5),
                (0, 0.5, 0)
            ]
            uniform token subdivisionScheme = "none"
            double3 xformOp:translate = (0, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }

        def Mesh "DuplicatePyramid2"
        {
            float3[] extent = [(-0.5, -0.5, -0.5), (0.5, 0.5, 0.5)]
            int[] faceVertexCounts = [4, 3, 3, 3, 3]
            int[] faceVertexIndices = [0, 1, 2, 3, 0, 1, 4, 1, 2, 4, 2, 3, 4, 3, 0, 4]
            point3f[] points = [
                (-0.5, -0.5, -0.5), (0.5, -0.5, -0.5), (0.5, -0.5, 0.5), (-0.5, -0.5, 0.5),
                (0, 0.5, 0)
            ]
            uniform token subdivisionScheme = "none"
            double3 xformOp:translate = (4, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }

        def Mesh "DuplicatePyramid3"
        {
            float3[] extent = [(-0.5, -0.5, -0.5), (0.5, 0.5, 0.5)]
            int[] faceVertexCounts = [4, 3, 3, 3, 3]
            int[] faceVertexIndices = [0, 1, 2, 3, 0, 1, 4, 1, 2, 4, 2, 3, 4, 3, 0, 4]
            point3f[] points = [
                (-0.5, -0.5, -0.5), (0.5, -0.5, -0.5), (0.5, -0.5, 0.5), (-0.5, -0.5, 0.5),
                (0, 0.5, 0)
            ]
            uniform token subdivisionScheme = "none"
            double3 xformOp:translate = (6, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }
    }

    # =========================================================================
    # SECTION 4: Combined Test (All Operations)
    # Uses DOUBLE TETRAHEDRONS - 8 vertices (2x4), 8 triangle faces (2x4)
    # Tests all operations: deinstancing + split + deduplication
    # - Instanceable references get deinstanced
    # - Mesh with GeomSubsets gets split into 2 tetrahedrons
    # - Identical tetrahedrons across instances get deduplicated
    # =========================================================================

    def Xform "CombinedTest"
    {
        double3 xformOp:translate = (0, 0, 15)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        # Prototype: Two identical tetrahedrons in one mesh with GeomSubsets
        def Mesh "PrototypeDoubleTetra" (
            instanceable = true
        )
        {
            float3[] extent = [(-2.5, -0.5, -0.5), (2.5, 0.5, 0.5)]
            # 8 faces: 4 triangles per tetrahedron
            int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3]
            int[] faceVertexIndices = [
                # Tetrahedron 1 (left) - vertices 0-3
                0, 1, 2, 0, 1, 3, 1, 2, 3, 2, 0, 3,
                # Tetrahedron 2 (right) - vertices 4-7
                4, 5, 6, 4, 5, 7, 5, 6, 7, 6, 4, 7
            ]
            point3f[] points = [
                # Tetrahedron 1 (left, centered at -2, 0, 0)
                (-2.5, -0.5, -0.5), (-1.5, -0.5, -0.5), (-2, -0.5, 0.5),
                (-2, 0.5, 0),
                # Tetrahedron 2 (right, centered at 2, 0, 0)
                (1.5, -0.5, -0.5), (2.5, -0.5, -0.5), (2, -0.5, 0.5),
                (2, 0.5, 0)
            ]
            uniform token subdivisionScheme = "none"

            def GeomSubset "Tetra_Left" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                uniform token elementType = "face"
                uniform token familyName = "materialBind"
                int[] indices = [0, 1, 2, 3]
            }

            def GeomSubset "Tetra_Right" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                uniform token elementType = "face"
                uniform token familyName = "materialBind"
                int[] indices = [4, 5, 6, 7]
            }
        }

        # Three instanceable references - will be deinstanced, split, then deduplicated
        def Xform "CombinedInstance1" (
            references = </World/CombinedTest/PrototypeDoubleTetra>
            instanceable = true
        )
        {
            double3 xformOp:translate = (0, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }

        def Xform "CombinedInstance2" (
            references = </World/CombinedTest/PrototypeDoubleTetra>
            instanceable = true
        )
        {
            double3 xformOp:translate = (0, 0, 3)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }

        def Xform "CombinedInstance3" (
            references = </World/CombinedTest/PrototypeDoubleTetra>
            instanceable = true
        )
        {
            double3 xformOp:translate = (0, 0, 6)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }
    }

    # =========================================================================
    # SECTION 5: Control Group
    # Uses OCTAHEDRON - 6 vertices, 8 triangle faces (unique topology)
    # Should remain unchanged
    # =========================================================================

    def Xform "ControlGroup"
    {
        double3 xformOp:translate = (0, 0, 20)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        def Mesh "SimpleMesh"
        {
            float3[] extent = [(-0.5, -0.5, -0.5), (0.5, 0.5, 0.5)]
            int[] faceVertexCounts = [3, 3, 3, 3, 3, 3, 3, 3]
            int[] faceVertexIndices = [
                0, 1, 4, 1, 2, 4, 2, 3, 4, 3, 0, 4,
                1, 0, 5, 2, 1, 5, 3, 2, 5, 0, 3, 5
            ]
            point3f[] points = [
                (0, 0, -0.5), (0.5, 0, 0), (0, 0, 0.5), (-0.5, 0, 0),
                (0, 0.5, 0), (0, -0.5, 0)
            ]
            uniform token subdivisionScheme = "none"
        }
    }

    # =========================================================================
    # SECTION 6: Deinstance + Split Test (no dedup)
    # Uses HEXAGONAL DISCS - 7 vertices (center + 6 outer), 6 triangle faces
    # - Instanceable references with GeomSubsets
    # - Run deinstancing + split, skip deduplication
    # =========================================================================

    def Xform "DeinstanceSplitTest"
    {
        double3 xformOp:translate = (0, 0, 25)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        # Prototype: flat hexagonal disc split into top and bottom halves
        def Mesh "PrototypeHexDisc" (
            instanceable = true
        )
        {
            float3[] extent = [(-1, 0, -0.866), (1, 0, 0.866)]
            int[] faceVertexCounts = [3, 3, 3, 3, 3, 3]
            int[] faceVertexIndices = [
                # Top half
                0, 1, 2,
                0, 2, 3,
                0, 3, 4,
                # Bottom half
                0, 4, 5,
                0, 5, 6,
                0, 6, 1
            ]
            point3f[] points = [
                (0, 0, 0),             # 0: center
                (1, 0, 0),             # 1: right
                (0.5, 0, 0.866),       # 2: upper-right
                (-0.5, 0, 0.866),      # 3: upper-left
                (-1, 0, 0),            # 4: left
                (-0.5, 0, -0.866),     # 5: lower-left
                (0.5, 0, -0.866)       # 6: lower-right
            ]
            uniform token subdivisionScheme = "none"

            def GeomSubset "Top_Half" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                uniform token elementType = "face"
                uniform token familyName = "materialBind"
                int[] indices = [0, 1, 2]
            }

            def GeomSubset "Bottom_Half" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                uniform token elementType = "face"
                uniform token familyName = "materialBind"
                int[] indices = [3, 4, 5]
            }
        }

        # Three instanceable references - will be deinstanced then split
        def Xform "HexInstance1" (
            references = </World/DeinstanceSplitTest/PrototypeHexDisc>
            instanceable = true
        )
        {
            double3 xformOp:translate = (0, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }

        def Xform "HexInstance2" (
            references = </World/DeinstanceSplitTest/PrototypeHexDisc>
            instanceable = true
        )
        {
            double3 xformOp:translate = (3, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }

        def Xform "HexInstance3" (
            references = </World/DeinstanceSplitTest/PrototypeHexDisc>
            instanceable = true
        )
        {
            double3 xformOp:translate = (6, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }
    }

    # =========================================================================
    # SECTION 7: Deinstance + Dedup Test (no split)
    # Uses FLAT DIAMONDS - 4 vertices, 2 triangle faces
    # - Instanceable references to identical geometry (no GeomSubsets)
    # - Run deinstancing + deduplication, skip split
    # =========================================================================

    def Xform "DeinstanceDedupTest"
    {
        double3 xformOp:translate = (0, 0, 30)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        # Prototype: flat diamond/rhombus shape
        def Mesh "PrototypeDiamond" (
            instanceable = true
        )
        {
            float3[] extent = [(-0.5, 0, -0.7), (0.5, 0, 0.7)]
            int[] faceVertexCounts = [3, 3]
            int[] faceVertexIndices = [0, 1, 2, 0, 2, 3]
            point3f[] points = [
                (0, 0, -0.7),     # 0: top
                (0.5, 0, 0),      # 1: right
                (0, 0, 0.7),      # 2: bottom
                (-0.5, 0, 0)      # 3: left
            ]
            uniform token subdivisionScheme = "none"
        }

        # Three instanceable references - will be deinstanced then deduplicated
        def Xform "DiamondInstance1" (
            references = </World/DeinstanceDedupTest/PrototypeDiamond>
            instanceable = true
        )
        {
            double3 xformOp:translate = (0, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }

        def Xform "DiamondInstance2" (
            references = </World/DeinstanceDedupTest/PrototypeDiamond>
            instanceable = true
        )
        {
            double3 xformOp:translate = (2, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }

        def Xform "DiamondInstance3" (
            references = </World/DeinstanceDedupTest/PrototypeDiamond>
            instanceable = true
        )
        {
            double3 xformOp:translate = (4, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]
        }
    }

    # =========================================================================
    # SECTION 8: Split + Dedup Test (no deinstance)
    # Uses ARROWS - 5 vertices, 3 triangle faces
    # - Non-instanced duplicate meshes with GeomSubsets
    # - Run split + deduplication, skip deinstancing
    # - After split, identical parts across meshes get deduplicated
    # =========================================================================

    def Xform "SplitDedupTest"
    {
        double3 xformOp:translate = (0, 0, 35)
        uniform token[] xformOpOrder = ["xformOp:translate"]

        # Three identical arrow meshes with GeomSubsets (non-instanced)
        # After split: ArrowHead and ArrowBody parts are identical across copies
        # After dedup: identical parts get deduplicated

        def Mesh "ArrowMesh1"
        {
            float3[] extent = [(-0.5, 0, -0.5), (0.5, 0, 1)]
            int[] faceVertexCounts = [3, 3, 3]
            int[] faceVertexIndices = [
                # Arrow head (tip triangle)
                0, 2, 1,
                # Arrow body (two triangles forming rectangle)
                0, 1, 4,
                0, 4, 3
            ]
            point3f[] points = [
                (-0.5, 0, 0),       # 0: left base
                (0.5, 0, 0),        # 1: right base
                (0, 0, 1),          # 2: tip
                (-0.5, 0, -0.5),    # 3: left tail
                (0.5, 0, -0.5)      # 4: right tail
            ]
            uniform token subdivisionScheme = "none"
            double3 xformOp:translate = (0, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]

            def GeomSubset "Arrow_Head" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                uniform token elementType = "face"
                uniform token familyName = "materialBind"
                int[] indices = [0]
            }

            def GeomSubset "Arrow_Body" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                uniform token elementType = "face"
                uniform token familyName = "materialBind"
                int[] indices = [1, 2]
            }
        }

        def Mesh "ArrowMesh2"
        {
            float3[] extent = [(-0.5, 0, -0.5), (0.5, 0, 1)]
            int[] faceVertexCounts = [3, 3, 3]
            int[] faceVertexIndices = [
                0, 2, 1,
                0, 1, 4,
                0, 4, 3
            ]
            point3f[] points = [
                (-0.5, 0, 0),
                (0.5, 0, 0),
                (0, 0, 1),
                (-0.5, 0, -0.5),
                (0.5, 0, -0.5)
            ]
            uniform token subdivisionScheme = "none"
            double3 xformOp:translate = (3, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]

            def GeomSubset "Arrow_Head" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                uniform token elementType = "face"
                uniform token familyName = "materialBind"
                int[] indices = [0]
            }

            def GeomSubset "Arrow_Body" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                uniform token elementType = "face"
                uniform token familyName = "materialBind"
                int[] indices = [1, 2]
            }
        }

        def Mesh "ArrowMesh3"
        {
            float3[] extent = [(-0.5, 0, -0.5), (0.5, 0, 1)]
            int[] faceVertexCounts = [3, 3, 3]
            int[] faceVertexIndices = [
                0, 2, 1,
                0, 1, 4,
                0, 4, 3
            ]
            point3f[] points = [
                (-0.5, 0, 0),
                (0.5, 0, 0),
                (0, 0, 1),
                (-0.5, 0, -0.5),
                (0.5, 0, -0.5)
            ]
            uniform token subdivisionScheme = "none"
            double3 xformOp:translate = (6, 0, 0)
            uniform token[] xformOpOrder = ["xformOp:translate"]

            def GeomSubset "Arrow_Head" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                uniform token elementType = "face"
                uniform token familyName = "materialBind"
                int[] indices = [0]
            }

            def GeomSubset "Arrow_Body" (
                prepend apiSchemas = ["MaterialBindingAPI"]
            )
            {
                uniform token elementType = "face"
                uniform token familyName = "materialBind"
                int[] indices = [1, 2]
            }
        }
    }
}
